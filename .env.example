# Server Configuration
PORT=3000
JWT_SECRET=your_jwt_secret_here

# Database Configuration (Supabase PostgreSQL)
# Get your connection string from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Use the "Transaction" pooler mode (port 6543) for best compatibility
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Email Configuration (Brevo)
# Get your API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your-api-key-here
# Use the email address verified in your Brevo account
BREVO_SENDER_EMAIL=your-verified-email@domain.com

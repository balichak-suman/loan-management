# Server Configuration
PORT=3000
JWT_SECRET=your_jwt_secret_here

# Database Configuration (Turso/SQLite)
# For local development, leave these blank to use local SQLite if supported, 
# or use your Turso credentials.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Email Configuration (Brevo)
# Get your API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your-api-key-here
# Use the email address verified in your Brevo account
BREVO_SENDER_EMAIL=your-verified-email@domain.com
